        ((2 * (N : ℚ)) / 25)^r * 3^p *
            GcompClosedBound r p /
          (r.factorial : ℚ) := by
  unfold positiveLargeTailSoloSharpGcompClosedInnerActive
  exact Finset.sum_subset (GcompClosedActiveRange_subset_range p)
