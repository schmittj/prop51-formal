      (by omega : 361 ≤ p) (by omega : 2 * p ≤ 3 * p)
  have hpow_nonneg : 0 ≤ (1 / 2 : ℚ)^p := by positivity
  have hdelta_coef :
      (72 / 125 : ℚ) + (1 / 2 : ℚ) * ((66 / 5 : ℚ) / (p : ℚ))
        ≤ 3 / 5 := by
    have hpQ : (275 : ℚ) ≤ (p : ℚ) := by
      exact_mod_cast (by omega : 275 ≤ p)
    rw [div_eq_mul_inv]
    field_simp [hp_pos.ne']
    nlinarith
  have hbracket :
      (72 / 125 : ℚ) * (1 / 2 : ℚ)^p +
          ((1 / 2 : ℚ) * (1 / 2 : ℚ)^p) *
            DeltaRat p ((posNhi a : ℚ) / 2)
        ≤ (3 / 5 : ℚ) * (1 / 2 : ℚ)^p := by
    have hdelta_term :
        ((1 / 2 : ℚ) * (1 / 2 : ℚ)^p) *
