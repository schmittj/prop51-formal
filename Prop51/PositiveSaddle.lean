      positiveLargeTailSoloSharpDeepLowHeadFactorialCrudeTerm a s *
        (((5 : ℚ) * (a : ℚ)) /
          ((6 : ℚ) * (p : ℚ) * ((s + 1 : Nat) : ℚ))) := by
    unfold positiveLargeTailSoloSharpDeepLowHeadFactorialCrudeTerm
    have hsub_pow : a - s = p + 1 := by
      dsimp [p]
      omega
    have hsub_succ : a - (s + 1) = p := by
