      (a : ℚ) *
          ((57 / 10 : ℚ) / ((r : ℚ) * ((r + 1 : Nat) : ℚ)) -
          (29 / 10 : ℚ) /
            (((posJ a r : Nat) : ℚ) * ((posJ a r - 1 : Nat) : ℚ)))
        = ((a : ℚ) / 10) *
