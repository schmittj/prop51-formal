      have hb : 0 ≤ (a : ℚ) - 2001 := by
        have : (2001 : ℚ) ≤ a := by exact_mod_cast (by omega : 2001 ≤ a)
        linarith
      have hEq :
          (a : ℚ)^4 + 15267 * (a : ℚ)^3 - 157590 * (a : ℚ)^2
              - 3105000 * (a : ℚ) + 44550000
            = ((a : ℚ) - 2001)^4
              + 23271 * ((a : ℚ) - 2001)^3
              + 115514217 * ((a : ℚ) - 2001)^2
              + 214801493625 * ((a : ℚ) - 2001)
              + 137714160552678 := by
        ring
