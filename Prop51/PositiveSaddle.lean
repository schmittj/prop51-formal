    rw [Nat.cast_sub (by omega : 1 ≤ 4 * a)]
    norm_num
  unfold positiveTemperedLowerExpQuotientTarget positiveLargeExpTemperedRatio
  rw [hjCast, hpredCast]
  field_simp [hrSuccPos.ne', hdenPos.ne']
  push_cast at hfrontQ haQ ⊢
  ring_nf at hfrontQ haQ ⊢
  nlinarith

