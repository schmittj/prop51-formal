/-- Interval form of the positive-degree factorial-only `X` inner closed
composition sum. -/
theorem positiveLargeTailXGcompClosedInnerFactorial_eq_Icc_of_pos
    {N p : Nat} (hp : 0 < p) :
    positiveLargeTailXGcompClosedInnerFactorial N p =
