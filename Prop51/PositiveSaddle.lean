  have hp_pos : (0 : ℚ) < (p : ℚ) := by exact_mod_cast hp_pos_nat
  have hp_large : 1350 ≤ p := by omega
  have hN_nonneg : 0 ≤ ((posNhi a : ℚ) / 2) := by positivity
  have hN40 :
