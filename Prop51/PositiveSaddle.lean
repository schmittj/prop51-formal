/-- Interval form of the positive-degree factorial-only `Y`/solo inner
closed-composition sum. -/
theorem positiveLargeTailYGcompClosedInnerFactorial_eq_Icc_of_pos
    {N p : Nat} (hp : 0 < p) :
    positiveLargeTailYGcompClosedInnerFactorial N p =
      ∑ r ∈ Finset.Icc 1 (p / 2),
