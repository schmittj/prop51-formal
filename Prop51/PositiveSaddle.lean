      positiveTemperedExponentUpper a r - positiveTemperedExponentUpper a (r + 1) := by
    rw [hdiff_eq]
    rw [← hmul_left, ← hmul_right]
    exact hmul
  have hfinal :
      positiveTemperedExponentUpper a (r + 1) + (175 : ℚ) / (4 * (a : ℚ))
