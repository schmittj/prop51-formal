  have hbase_nonneg : 0 ≤ (5 * (posNhi a : ℚ) / 12) := by
    positivity
  have hbase_le :
      5 * (posNhi a : ℚ) / 12 ≤ 5 * (a : ℚ) := by
    nlinarith
  have hpow_le :
      (5 * (posNhi a : ℚ) / 12)^s ≤ (5 * (a : ℚ))^s :=
    pow_le_pow_left₀ hbase_nonneg hbase_le s
