theorem positiveLargeTailYGcompClosedFactorialBlockSum_eq_splitBlockSum
    (N j : Nat) :
    positiveLargeTailYGcompClosedFactorialBlockSum N j =
      positiveLargeTailYGcompClosedFactorialSplitBlockSum N j := by
