/-- Interval form of the split-final-term factorial-only `Y`/solo block
sum. -/
theorem positiveLargeTailYGcompClosedFactorialSplitBlockSum_eq_Icc
    (N j : Nat) :
    positiveLargeTailYGcompClosedFactorialSplitBlockSum N j =
      (∑ s ∈ Finset.range j,
