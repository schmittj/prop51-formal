            rw [hcancel]
            ring
  have hscaled_eq :
      (4 : ℚ) * (2 : ℚ)^a *
          ((((posNhi a : ℚ) / 2 * c 1 / 2)^s /
              (s.factorial : ℚ)) *
            ((posNhi a : ℚ) * c (a - s) *
