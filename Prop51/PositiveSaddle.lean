theorem positiveTemperedExponentUpper_upperMiddleShiftBudget_le_cutoff_div_twentyfour
    {a r : Nat} (ha : 2000 < a)
    (hrlo : positiveLargeExpTemperedSplit a + 1 < r)
    (hrhi : r ≤ posKmax a) (hmid : 5 * r < 3 * a) :
