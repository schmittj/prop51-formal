          have hden2 : 810 - (a : ℚ) * 114 + (a : ℚ)^2 * 4 ≠ 0 := by
            have hpos :
                (0 : ℚ) < 810 - (a : ℚ) * 114 + (a : ℚ)^2 * 4 := by
