  exact positiveLargeTailYGcompClosedBlockSum_nonneg N a

theorem positiveLargeTailSoloGcompClosedFactorialBlockSum_nonneg
    (a N : Nat) :
    0 ≤ positiveLargeTailSoloGcompClosedFactorialBlockSum a N := by
