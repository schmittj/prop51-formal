    simpa [mul_assoc] using mul_le_mul_of_nonneg_left hprod hscale
  have hright :
      192 * ((k : ℚ) * (posJ a k : ℚ)) *
          positiveTemperedLargeExpFast a k *
            ((posNlo a : ℚ) * c k * c (posJ a k))
        ≤ 192 * ((k : ℚ) * (posJ a k : ℚ)) *
