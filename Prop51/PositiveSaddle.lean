def positiveTemperedLowerFirstTenSeventhsEnvelopeTerm (a : Nat) : ℚ :=
  (800000000 : ℚ) *
    (((4 * a : Nat) : ℚ) *
      (positiveTemperedEntropyShadowBaseTerm a
        (max 1 (posTemperedCutoff a + 1)) *
          positiveTemperedReserveTenSeventhsExpBound a))

/-- Coarse Lean-side majorant for the first tempered endpoint reserve.

The TeX estimate uses the endpoint entropy decay directly.  Here we first
throw away the entropy-shadow binomial ratio (`≤ 1`), bound the first
tempered index by `a/4`, and keep only the dyadic decay
`2^{-(a-a/4)}`.  This is much rougher but still has large margin with the
sharp `(10/7)^a` exponential envelope. -/
def positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm (a : Nat) : ℚ :=
  (3200000000 : ℚ) * (a : ℚ)^3 *
    (positiveDyadicDecay (a - a / 4) *
      positiveTemperedReserveTenSeventhsExpBound a)

theorem positiveTemperedLowerFirstTenSeventhsEnvelopeTerm_le_coarse
    {a : Nat} (ha : 2000 < a) :
    positiveTemperedLowerFirstTenSeventhsEnvelopeTerm a
      ≤ positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm a := by
  let k := max 1 (posTemperedCutoff a + 1)
  have hkRange : k ∈ positiveKRange a :=
    mem_positiveKRange.mpr
      ⟨le_max_left _ _, positiveTemperedBranch_start_le_posKmax_of_large ha⟩
  have hbase :
      positiveTemperedEntropyShadowBaseTerm a k ≤
        (96 / (posNlo a : ℚ)) *
            ((k : ℚ) * (posJ a k : ℚ)) *
          positiveDyadicDecay (posJ a k) :=
    positiveTemperedEntropyShadowBaseTerm_le_simple
      (by omega : 20 ≤ a) hkRange
  have hExp_nonneg :
      0 ≤ positiveTemperedReserveTenSeventhsExpBound a := by
    unfold positiveTemperedReserveTenSeventhsExpBound
    positivity
  have hbaseExp :
      positiveTemperedEntropyShadowBaseTerm a k *
          positiveTemperedReserveTenSeventhsExpBound a
        ≤
      ((96 / (posNlo a : ℚ)) *
            ((k : ℚ) * (posJ a k : ℚ)) *
          positiveDyadicDecay (posJ a k)) *
        positiveTemperedReserveTenSeventhsExpBound a :=
    mul_le_mul_of_nonneg_right hbase hExp_nonneg
  have hkQuarter : k ≤ a / 4 := by
    dsimp [k]
    exact positiveTemperedBranch_start_le_quarter_self_of_large ha
  have hk_le_a : k ≤ a := by
    have hquarter_le : a / 4 ≤ a := Nat.div_le_self a 4
    omega
  have hj_le_a : posJ a k ≤ a := by
    unfold posJ
    omega
  have hkj_nat : k * posJ a k ≤ a * a :=
    Nat.mul_le_mul hk_le_a hj_le_a
  have hkj :
      (k : ℚ) * (posJ a k : ℚ) ≤ (a : ℚ)^2 := by
    rw [sq]
    exact_mod_cast hkj_nat
  have hdyadic_index : a - a / 4 ≤ posJ a k := by
    unfold posJ
    omega
  have hdyadic :
      positiveDyadicDecay (posJ a k) ≤
        positiveDyadicDecay (a - a / 4) :=
    positiveDyadicDecay_le_of_le hdyadic_index
  have hcoef :
      96 / (posNlo a : ℚ) ≤ 1 := by
    have hden : (0 : ℚ) < (posNlo a : ℚ) := by
      exact_mod_cast posNlo_pos (by omega : 2 ≤ a)
    rw [div_le_iff₀ hden]
    simpa using (show (96 : ℚ) ≤ (posNlo a : ℚ) by
      exact_mod_cast (by
        unfold posNlo
        omega : 96 ≤ posNlo a))
  have hsimple :
      ((96 / (posNlo a : ℚ)) *
            ((k : ℚ) * (posJ a k : ℚ)) *
          positiveDyadicDecay (posJ a k)) *
        positiveTemperedReserveTenSeventhsExpBound a
        ≤
      (a : ℚ)^2 *
        (positiveDyadicDecay (a - a / 4) *
          positiveTemperedReserveTenSeventhsExpBound a) := by
    calc
      ((96 / (posNlo a : ℚ)) *
            ((k : ℚ) * (posJ a k : ℚ)) *
          positiveDyadicDecay (posJ a k)) *
        positiveTemperedReserveTenSeventhsExpBound a
          ≤
        (1 * (a : ℚ)^2 *
            positiveDyadicDecay (a - a / 4)) *
          positiveTemperedReserveTenSeventhsExpBound a := by
            gcongr
            exact positiveDyadicDecay_nonneg (posJ a k)
      _ = (a : ℚ)^2 *
          (positiveDyadicDecay (a - a / 4) *
            positiveTemperedReserveTenSeventhsExpBound a) := by
            ring
  have hinner :
      positiveTemperedEntropyShadowBaseTerm a k *
          positiveTemperedReserveTenSeventhsExpBound a
        ≤
      (a : ℚ)^2 *
        (positiveDyadicDecay (a - a / 4) *
          positiveTemperedReserveTenSeventhsExpBound a) :=
    hbaseExp.trans hsimple
  have hscale :
      0 ≤ (800000000 : ℚ) * ((4 * a : Nat) : ℚ) := by positivity
  calc
    positiveTemperedLowerFirstTenSeventhsEnvelopeTerm a
        ≤ (800000000 : ℚ) * (((4 * a : Nat) : ℚ) *
            ((a : ℚ)^2 *
              (positiveDyadicDecay (a - a / 4) *
                positiveTemperedReserveTenSeventhsExpBound a))) := by
          simpa [positiveTemperedLowerFirstTenSeventhsEnvelopeTerm, k,
            mul_assoc, mul_left_comm, mul_comm] using
            mul_le_mul_of_nonneg_left hinner hscale
    _ = positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm a := by
          unfold positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm
          norm_num [Nat.cast_mul]
          ring

theorem positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm_add_four_le
    {a : Nat} (ha : 2001 ≤ a) :
    positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm (a + 4)
      ≤ positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm a := by
  have hdiv : (a + 4) / 4 = a / 4 + 1 := by
    exact Nat.add_div_right a (by decide : 0 < 4)
  have hsub : a + 4 - (a + 4) / 4 = (a - a / 4) + 3 := by
    rw [hdiv]
    omega
  have hpow2 : (0 : ℚ) < (2 : ℚ)^(a - a / 4) := by positivity
  have hpow10 : (0 : ℚ) < (10 / 7 : ℚ)^a := by positivity
  unfold positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm
    positiveDyadicDecay positiveTemperedReserveTenSeventhsExpBound
  rw [hsub]
  rw [show (10 / 7 : ℚ)^(a + 4) =
      (10 / 7 : ℚ)^a * (10 / 7 : ℚ)^4 by
        rw [pow_add]]
  rw [show (2 : ℚ)^((a - a / 4) + 3) =
      (2 : ℚ)^(a - a / 4) * (2 : ℚ)^3 by
        rw [pow_add]]
  field_simp [hpow2.ne', hpow10.ne']
  ring_nf
  have haQ : (2001 : ℚ) ≤ (a : ℚ) := by exact_mod_cast ha
  have hstep : (a : ℚ) + 4 ≤ (401 / 400 : ℚ) * (a : ℚ) := by
    nlinarith
  have hcubed :
      ((a : ℚ) + 4)^3 ≤ ((401 / 400 : ℚ) * (a : ℚ))^3 :=
    pow_le_pow_left₀ (by positivity : (0 : ℚ) ≤ (a : ℚ) + 4) hstep 3
  have hconst : (10000 : ℚ) * (401 / 400 : ℚ)^3 ≤ 19208 := by
    norm_num
  have hcubed_scaled :
      (10000 : ℚ) * ((a : ℚ) + 4)^3
        ≤ 10000 * ((401 / 400 : ℚ) * (a : ℚ))^3 :=
    mul_le_mul_of_nonneg_left hcubed (by norm_num)
  have hconst_scaled :
      (10000 : ℚ) * ((401 / 400 : ℚ) * (a : ℚ))^3
        ≤ 19208 * (a : ℚ)^3 := by
    have ha3 : 0 ≤ (a : ℚ)^3 := by positivity
    calc
      (10000 : ℚ) * ((401 / 400 : ℚ) * (a : ℚ))^3
          = (10000 * (401 / 400 : ℚ)^3) * (a : ℚ)^3 := by
            ring
      _ ≤ 19208 * (a : ℚ)^3 :=
            mul_le_mul_of_nonneg_right hconst ha3
  have htarget :
      ((4 + a : Nat) : ℚ)^3 * 10000 ≤ (a : ℚ)^3 * 19208 := by
    have h' := hcubed_scaled.trans hconst_scaled
    have hadd : ((4 + a : Nat) : ℚ) = (a : ℚ) + 4 := by
      norm_num [Nat.cast_add, add_comm]
    rw [hadd]
    ring_nf at h' ⊢
    exact h'
  nlinarith

theorem positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm_le_one
    {a : Nat} (ha : 2000 < a) :
    positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm a ≤ 1 := by
  have ha2001 : 2001 ≤ a := by omega
  revert ha2001
  refine Nat.strong_induction_on a ?_
  intro n ih hn
  by_cases hbase : n ≤ 2004
  · have hcases : n = 2001 ∨ n = 2002 ∨ n = 2003 ∨ n = 2004 := by
      omega
    rcases hcases with rfl | rfl | rfl | rfl <;> native_decide
  · have hnprev : 2001 ≤ n - 4 := by omega
    have hprev :
        positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm (n - 4)
          ≤ 1 :=
      ih (n - 4) (by omega) hnprev
    have hstep :=
      positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm_add_four_le
        (a := n - 4) hnprev
    have hrewrite : n - 4 + 4 = n := by omega
    rw [hrewrite] at hstep
    exact hstep.trans hprev

theorem positiveTemperedLowerFirstTenSeventhsEnvelopeTerm_le_one
    {a : Nat} (ha : 2000 < a) :
    positiveTemperedLowerFirstTenSeventhsEnvelopeTerm a ≤ 1 :=
  (positiveTemperedLowerFirstTenSeventhsEnvelopeTerm_le_coarse ha).trans
    (positiveTemperedLowerFirstTenSeventhsCoarseEnvelopeTerm_le_one ha)

theorem positiveTemperedLowerFirstTenSeventhsEnvelopeUnit
    {a : Nat} (ha : 2000 < a) :
    (800000000 : ℚ) *
        (((4 * a : Nat) : ℚ) *
          (positiveTemperedEntropyShadowBaseTerm a
            (max 1 (posTemperedCutoff a + 1)) *
              positiveTemperedReserveTenSeventhsExpBound a))
      ≤ 1 :=
  positiveTemperedLowerFirstTenSeventhsEnvelopeTerm_le_one ha

theorem positiveSaddleLargeTailCandidateTemperedLowerFirstReserveEnvelopeCertificate_tenSevenths_closed :
    PositiveSaddleLargeTailCandidateTemperedLowerFirstReserveEnvelopeCertificate
      positiveTemperedReserveTenSeventhsExpBound :=
  positiveSaddleLargeTailCandidateTemperedLowerFirstReserveEnvelopeCertificate_tenSevenths
    (fun ha => positiveTemperedLowerFirstTenSeventhsEnvelopeUnit ha)

def positiveTemperedUpperLastTenSeventhsEnvelopeTerm (a : Nat) : ℚ :=
  (800000000 : ℚ) *
    (((4 * a : Nat) : ℚ) *
      (positiveTemperedEntropyShadowBaseTerm a (posKmax a) *
        positiveTemperedReserveTenSeventhsExpBound a))

/-- Coarse Lean-side majorant for the last tempered endpoint reserve.

This keeps the essential entropy decay at `k = posKmax a`: the two
entropy-shadow ratios are bounded by `901/1000` and `101/1000`, and the
dyadic factor is kept at exponent `a/10`.  The remaining proof is then a
100-step monotonicity argument plus a finite base interval. -/
def positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm (a : Nat) : ℚ :=
  (3200000000 : ℚ) * (a : ℚ)^3 *
    ((901 / 1000 : ℚ)^(89 * a / 100) *
      ((101 / 1000 : ℚ)^(a / 10 - 1) *
        (positiveDyadicDecay (a / 10) *
          positiveTemperedReserveTenSeventhsExpBound a)))

theorem positiveTemperedUpperLastTenSeventhsEnvelopeTerm_le_coarse
    {a : Nat} (ha : 2000 < a) :
    positiveTemperedUpperLastTenSeventhsEnvelopeTerm a
      ≤ positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm a := by
  have hkRange : posKmax a ∈ positiveKRange a :=
    mem_positiveKRange.mpr
      ⟨one_le_posKmax (by omega : 2 ≤ a), le_rfl⟩
  have hB :
      positiveBinomRatioEntropyShadowPosJBound a (posKmax a) ≤
        (901 / 1000 : ℚ)^(89 * a / 100) *
          (101 / 1000 : ℚ)^(a / 10 - 1) := by
    have hBraw :=
      positiveBinomRatioEntropyShadowPosJBound_posKmax_le_901_101 ha
    have h901 :
        (901 / 1000 : ℚ)^(posKmax a - 1) ≤
          (901 / 1000 : ℚ)^(89 * a / 100) :=
      rat_pow_le_pow_of_le_one (by norm_num) (by norm_num)
        (eightyNine_mul_self_div_hundred_le_posKmax_pred
          (a := a) (by omega : 190 ≤ a))
    have h101 :
        (101 / 1000 : ℚ)^(posJ a (posKmax a) - 1) ≤
          (101 / 1000 : ℚ)^(a / 10 - 1) :=
      rat_pow_le_pow_of_le_one (by norm_num) (by norm_num)
        (self_div_ten_sub_one_le_posJ_posKmax_pred (a := a))
    exact hBraw.trans
      (mul_le_mul h901 h101 (by positivity) (by positivity))
  have hcoef :
      96 / (posNlo a : ℚ) ≤ 1 := by
    have hden : (0 : ℚ) < (posNlo a : ℚ) := by
      exact_mod_cast posNlo_pos (by omega : 2 ≤ a)
    rw [div_le_iff₀ hden]
    simpa using (show (96 : ℚ) ≤ (posNlo a : ℚ) by
      exact_mod_cast (by
        unfold posNlo
        omega : 96 ≤ posNlo a))
  have hk_le_a : posKmax a ≤ a :=
    le_of_lt (posKmax_lt_self (a := a) (by omega : 1 ≤ a))
  have hj_le_a : posJ a (posKmax a) ≤ a := by
    unfold posJ
    omega
  have hkj_nat : posKmax a * posJ a (posKmax a) ≤ a * a :=
    Nat.mul_le_mul hk_le_a hj_le_a
  have hkj :
      (posKmax a : ℚ) * (posJ a (posKmax a) : ℚ) ≤ (a : ℚ)^2 := by
    rw [sq]
    exact_mod_cast hkj_nat
  have hdyadic :
      positiveDyadicDecay (posJ a (posKmax a)) ≤
        positiveDyadicDecay (a / 10) :=
    positiveDyadicDecay_le_of_le (self_div_ten_le_posJ_posKmax (a := a))
  have hExp_nonneg :
      0 ≤ positiveTemperedReserveTenSeventhsExpBound a := by
    unfold positiveTemperedReserveTenSeventhsExpBound
    positivity
  have hbaseExp :
      positiveTemperedEntropyShadowBaseTerm a (posKmax a) *
          positiveTemperedReserveTenSeventhsExpBound a
        ≤
      (a : ℚ)^2 *
        ((901 / 1000 : ℚ)^(89 * a / 100) *
          ((101 / 1000 : ℚ)^(a / 10 - 1) *
            (positiveDyadicDecay (a / 10) *
              positiveTemperedReserveTenSeventhsExpBound a))) := by
    unfold positiveTemperedEntropyShadowBaseTerm
    calc
      ((96 / (posNlo a : ℚ)) *
            ((posKmax a : ℚ) * (posJ a (posKmax a) : ℚ)) *
          positiveBinomRatioEntropyShadowPosJBound a (posKmax a) *
        positiveDyadicDecay (posJ a (posKmax a))) *
          positiveTemperedReserveTenSeventhsExpBound a
          ≤
        (1 * (a : ℚ)^2 *
            ((901 / 1000 : ℚ)^(89 * a / 100) *
              (101 / 1000 : ℚ)^(a / 10 - 1)) *
          positiveDyadicDecay (a / 10)) *
          positiveTemperedReserveTenSeventhsExpBound a := by
            gcongr
            exact positiveDyadicDecay_nonneg (posJ a (posKmax a))
            exact positiveBinomRatioEntropyShadowPosJBound_nonneg a (posKmax a)
      _ =
        (a : ℚ)^2 *
          ((901 / 1000 : ℚ)^(89 * a / 100) *
            ((101 / 1000 : ℚ)^(a / 10 - 1) *
              (positiveDyadicDecay (a / 10) *
                positiveTemperedReserveTenSeventhsExpBound a))) := by
            ring
  have hscale :
      0 ≤ (800000000 : ℚ) * ((4 * a : Nat) : ℚ) := by positivity
  calc
    positiveTemperedUpperLastTenSeventhsEnvelopeTerm a
        ≤ (800000000 : ℚ) * (((4 * a : Nat) : ℚ) *
            ((a : ℚ)^2 *
              ((901 / 1000 : ℚ)^(89 * a / 100) *
                ((101 / 1000 : ℚ)^(a / 10 - 1) *
                  (positiveDyadicDecay (a / 10) *
                    positiveTemperedReserveTenSeventhsExpBound a))))) := by
          simpa [positiveTemperedUpperLastTenSeventhsEnvelopeTerm,
            mul_assoc, mul_left_comm, mul_comm] using
            mul_le_mul_of_nonneg_left hbaseExp hscale
    _ = positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm a := by
          unfold positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm
          norm_num [Nat.cast_mul]
          ring

theorem positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm_add_hundred_le
    {a : Nat} (ha : 2001 ≤ a) :
    positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm (a + 100)
      ≤ positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm a := by
  have hdiv89 : 89 * (a + 100) / 100 = 89 * a / 100 + 89 := by
    rw [show 89 * (a + 100) = 89 * a + 89 * 100 by ring]
    exact Nat.add_mul_div_right (89 * a) 89 (by decide : 0 < 100)
  have hdiv10 : (a + 100) / 10 = a / 10 + 10 := by
    rw [show a + 100 = a + 10 * 10 by ring]
    exact Nat.add_mul_div_right a 10 (by decide : 0 < 10)
  have hdiv10sub : a / 10 + 10 - 1 = (a / 10 - 1) + 10 := by
    have ha10 : 1 ≤ a / 10 := by
      exact (Nat.le_div_iff_mul_le (by norm_num : 0 < 10)).mpr
        (by omega : 1 * 10 ≤ a)
    omega
  have hpow901 : (0 : ℚ) < (901 / 1000 : ℚ)^(89 * a / 100) := by
    positivity
  have hpow101 : (0 : ℚ) < (101 / 1000 : ℚ)^(a / 10 - 1) := by
    positivity
  have hpow2 : (0 : ℚ) < (2 : ℚ)^(a / 10) := by positivity
  have hpow10 : (0 : ℚ) < (10 / 7 : ℚ)^a := by positivity
  unfold positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm
    positiveDyadicDecay positiveTemperedReserveTenSeventhsExpBound
  rw [hdiv89, hdiv10, hdiv10sub]
  rw [show (901 / 1000 : ℚ)^(89 * a / 100 + 89) =
      (901 / 1000 : ℚ)^(89 * a / 100) *
        (901 / 1000 : ℚ)^89 by
        rw [pow_add]]
  rw [show (101 / 1000 : ℚ)^(a / 10 - 1 + 10) =
      (101 / 1000 : ℚ)^(a / 10 - 1) *
        (101 / 1000 : ℚ)^10 by
        rw [pow_add]]
  rw [show (2 : ℚ)^(a / 10 + 10) =
      (2 : ℚ)^(a / 10) * (2 : ℚ)^10 by
        rw [pow_add]]
  rw [show (10 / 7 : ℚ)^(a + 100) =
      (10 / 7 : ℚ)^a * (10 / 7 : ℚ)^100 by
        rw [pow_add]]
  field_simp [hpow901.ne', hpow101.ne', hpow2.ne', hpow10.ne']
  ring_nf
  have haQ : (2001 : ℚ) ≤ (a : ℚ) := by exact_mod_cast ha
  have hstep : (a : ℚ) + 100 ≤ (21 / 20 : ℚ) * (a : ℚ) := by
    nlinarith
  have hcubed :
      ((a : ℚ) + 100)^3 ≤ ((21 / 20 : ℚ) * (a : ℚ))^3 :=
    pow_le_pow_left₀ (by positivity : (0 : ℚ) ≤ (a : ℚ) + 100) hstep 3
  have hconst :
      (21 / 20 : ℚ)^3 *
          (901 / 1000 : ℚ)^89 *
          (101 / 1000 : ℚ)^10 *
          (10 / 7 : ℚ)^100
        ≤ (2 : ℚ)^10 := by
    norm_num
  have htail_nonneg :
      0 ≤
        (901 / 1000 : ℚ)^89 *
          (101 / 1000 : ℚ)^10 *
          (10 / 7 : ℚ)^100 := by positivity
  have htarget_high :
      ((a : ℚ) + 100)^3 *
          ((901 / 1000 : ℚ)^89 *
            (101 / 1000 : ℚ)^10 *
            (10 / 7 : ℚ)^100)
        ≤ (a : ℚ)^3 * (2 : ℚ)^10 := by
    calc
      ((a : ℚ) + 100)^3 *
          ((901 / 1000 : ℚ)^89 *
            (101 / 1000 : ℚ)^10 *
            (10 / 7 : ℚ)^100)
          ≤
        ((21 / 20 : ℚ) * (a : ℚ))^3 *
          ((901 / 1000 : ℚ)^89 *
            (101 / 1000 : ℚ)^10 *
            (10 / 7 : ℚ)^100) :=
            mul_le_mul_of_nonneg_right hcubed htail_nonneg
      _ =
        (a : ℚ)^3 *
          ((21 / 20 : ℚ)^3 *
            (901 / 1000 : ℚ)^89 *
            (101 / 1000 : ℚ)^10 *
            (10 / 7 : ℚ)^100) := by
            ring
      _ ≤ (a : ℚ)^3 * (2 : ℚ)^10 :=
            mul_le_mul_of_nonneg_left hconst (by positivity)
  have htarget :
      ((100 + a : Nat) : ℚ)^3 *
          ((901 / 1000 : ℚ)^89 *
            (101 / 1000 : ℚ)^10 *
            (10 / 7 : ℚ)^100)
        ≤ (a : ℚ)^3 * (2 : ℚ)^10 := by
    have hadd : ((100 + a : Nat) : ℚ) = (a : ℚ) + 100 := by
      norm_num [Nat.cast_add, add_comm]
    rw [hadd]
    exact htarget_high
  norm_num at htarget
  field_simp at htarget
  ring_nf at htarget
  norm_num [Nat.cast_add, add_comm] at *
  ring_nf at *
  nlinarith

theorem positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm_le_one
    {a : Nat} (ha : 2000 < a) :
    positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm a ≤ 1 := by
  have hbase :
      ∀ n ∈ Finset.Icc 2001 2100,
        positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm n ≤ 1 := by
    native_decide
  have ha2001 : 2001 ≤ a := by omega
  revert ha2001
  refine Nat.strong_induction_on a ?_
  intro n ih hn
  by_cases hle : n ≤ 2100
  · exact hbase n (Finset.mem_Icc.mpr ⟨hn, hle⟩)
  · have hnprev : 2001 ≤ n - 100 := by omega
    have hprev :
        positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm (n - 100)
          ≤ 1 :=
      ih (n - 100) (by omega) hnprev
    have hstep :=
      positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm_add_hundred_le
        (a := n - 100) hnprev
    have hrewrite : n - 100 + 100 = n := by omega
    rw [hrewrite] at hstep
    exact hstep.trans hprev

theorem positiveTemperedUpperLastTenSeventhsEnvelopeTerm_le_one
    {a : Nat} (ha : 2000 < a) :
    positiveTemperedUpperLastTenSeventhsEnvelopeTerm a ≤ 1 :=
  (positiveTemperedUpperLastTenSeventhsEnvelopeTerm_le_coarse ha).trans
    (positiveTemperedUpperLastTenSeventhsCoarseEnvelopeTerm_le_one ha)

theorem positiveTemperedUpperLastTenSeventhsEnvelopeUnit
