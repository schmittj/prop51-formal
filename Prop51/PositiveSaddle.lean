  have hQ_pow :
      QqEplusGcompBound N a
        ≤ (29 * (a : ℚ) * c a * (10 / 7 : ℚ)^a) /
          ((4 : ℚ) * (2 : ℚ)^a) := by
    rw [le_div_iff₀ hscale]
    simpa [positiveLargeTailSoloGcompSaddleTenSeventhsCleared, mul_assoc,
