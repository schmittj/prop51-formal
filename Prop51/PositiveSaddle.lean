          positiveSmallEntropyShadowExpMajorantTerm smallExp a r ≤ q) :
    positiveSmallEntropyShadowExpMajorantTerm smallExp a (r + 1)
      ≤ positiveSmallEntropyShadowExpMajorantTerm smallExp a r * q :=
  le_mul_of_div_le_pos hpos hquot

