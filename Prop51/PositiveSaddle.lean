      (a := a) (N := N) (M := posNhi a) (k := k) hrect.2
  have hscale : 0 ≤ 2 * (2 : ℚ)^(posJ a k) * (posNlo a : ℚ) := by
    positivity
  have hleft :
      2 * (2 : ℚ)^(posJ a k) * (posNlo a : ℚ) *
          positiveLargeTailProductXClosedFactorialSplitBlockBound a N k *
