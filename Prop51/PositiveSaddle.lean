def positiveLargeTailYGcompClosedFactorialSplitBlockSum (N j : Nat) : ℚ :=
  (∑ s ∈ Finset.range j,
    (((N : ℚ) / 2 * c 1 / 2)^s / (s.factorial : ℚ)) *
